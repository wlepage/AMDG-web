---
import Section from './Section.astro';
import { ABOUT } from '@lib/content';
const { mission, vision, approach } = ABOUT;

const blocks = [
  { title: mission.eyebrow, paragraphs: [mission.text] },
  { title: vision.eyebrow, paragraphs: [vision.text] },
  { title: approach.eyebrow, paragraphs: [approach.intro, approach.closing] },
];
---
<Section id="about" heading="About">
  <div class="about">
    {blocks.map((b) => (
      <article class="about__box card">
        <h3 class="about__title">{b.title}</h3>
        {b.paragraphs.map((par) => (
          <p class="about__text">
            {par.split('\n').map((line, i) => (
              <Fragment>{i > 0 && <br />}{line}</Fragment>
            ))}
          </p>
        ))}
      </article>
    ))}
  </div>
</Section>

<style>
  .about { display: grid; gap: var(--space-5); grid-template-columns: 1fr; }
  @media (min-width: 800px) {
    .about { grid-template-columns: repeat(3, 1fr); }
  }
  .about__box {
    display: flex; flex-direction: column; gap: var(--space-4);
    padding: var(--space-6);
  }
  .about__title {
    font-family: var(--font-serif); font-weight: 700;
    font-size: clamp(1.5rem, 2.6vw, 1.9rem); line-height: 1.15;
    color: var(--c-brand-primary);
  }
  .about__text {
    font-size: 1.1rem; line-height: 1.5; color: var(--c-text);
  }
</style>
