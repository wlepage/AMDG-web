---
import Section from './Section.astro';
import { CONTACT } from '@lib/content';
---
<Section id="contact" heading="Contact" tint={true}>
  <address class="contact__address">
    {CONTACT.lab.lines.map((line) => <span>{line}</span>)}
  </address>
</Section>

<style>
  .contact__address {
    font-style: normal; display: grid; gap: 2px;
    color: var(--c-text); font-size: 1.05rem;
  }
</style>
