---
import Section from './Section.astro';
import ProjectCard from './ProjectCard.astro';
import { PROJECTS, FUNDERS } from '@lib/content';

// Current projects show in the main grid; any flagged `"earlier": true` collapse
// into the "Completed projects" disclosure below (mirrors the Highlights fold).
const current = PROJECTS.filter((p) => !p.earlier);
const earlier = PROJECTS.filter((p) => p.earlier);
---
<Section id="projects" heading="Active Projects">
  <ul class="projects">
    {current.map((p) => <ProjectCard project={p} />)}
  </ul>

  {earlier.length > 0 && (
    <details class="year-fold">
      <summary class="year-fold__summary">
        <span class="year-fold__year">Completed Projects</span>
        <svg class="year-fold__chevron" viewBox="0 0 20 20" aria-hidden="true" width="20" height="20">
          <path d="M5 7.5 L10 12.5 L15 7.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </summary>
      <ul class="projects year-fold__list">
        {earlier.map((p) => <ProjectCard project={p} />)}
      </ul>
    </details>
  )}

  {FUNDERS?.image && (
    <div class="funders">
      <h3 class="funders__heading">{FUNDERS.heading}</h3>
      <img src={FUNDERS.image} alt={FUNDERS.alt} loading="lazy" decoding="async" />
    </div>
  )}
</Section>

<style>
  .projects {
    list-style: none; margin: 0; padding: 0;
    display: grid; gap: var(--space-5);
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  }

  /* ---- Completed projects: a single line-divided disclosure (matches Highlights) ---- */
  .year-fold {
    margin-top: var(--space-7);
    border-top: 1px solid var(--c-border);
    border-bottom: 1px solid var(--c-border);
  }
  .year-fold[open] { border-bottom: 0; }
  .year-fold__summary {
    display: flex; align-items: center; gap: var(--space-3);
    cursor: pointer; list-style: none;
    padding: var(--space-4) 0;
    font-family: var(--font-serif); font-weight: 700; font-size: 1.15rem; color: var(--c-text);
  }
  .year-fold__summary::-webkit-details-marker { display: none; }
  .year-fold__year { flex: 1; }
  .year-fold__summary:hover .year-fold__year { color: var(--c-brand-primary); }
  .year-fold__chevron { color: var(--c-muted-text); transition: transform 0.2s ease; flex: 0 0 auto; }
  .year-fold[open] .year-fold__chevron { transform: rotate(180deg); }
  .year-fold__list { padding: var(--space-2) 0 var(--space-5); }

  .funders { margin-top: var(--space-8); text-align: center; }
  .funders__heading {
    font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.12em;
    color: var(--c-muted-text); font-family: var(--font-sans); font-weight: 600;
    margin-bottom: var(--space-5);
  }
  .funders img {
    margin-inline: auto; max-width: 480px; width: 100%; height: auto;
    border-radius: var(--radius); border: 1px solid var(--c-border);
    background: var(--c-background); padding: var(--space-4);
  }
</style>
